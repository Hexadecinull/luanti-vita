--- a/irr/source/Irrlicht/CIrrDeviceSDL.cpp
+++ b/irr/source/Irrlicht/CIrrDeviceSDL.cpp
@@ -1,5 +1,11 @@
 // SDL device for Irrlicht
 
+#ifdef __vita__
+#include "vitaGL.h"
+#define SDL_GL_CONTEXT_PROFILE_MASK   SDL_GL_CONTEXT_PROFILE_ES
+#define SDL_GL_CONTEXT_MAJOR_VERSION  2
+#define SDL_GL_CONTEXT_MINOR_VERSION  0
+#endif
+
 #ifdef _IRR_COMPILE_WITH_SDL_DEVICE_
 
 // -- vita: force GLES2 attributes before window creation --
@@ -80,6 +86,19 @@ bool CIrrDeviceSDL::createWindow()
+#ifdef __vita__
+	SDL_GL_SetAttribute(SDL_GL_CONTEXT_PROFILE_MASK,  SDL_GL_CONTEXT_PROFILE_ES);
+	SDL_GL_SetAttribute(SDL_GL_CONTEXT_MAJOR_VERSION, 2);
+	SDL_GL_SetAttribute(SDL_GL_CONTEXT_MINOR_VERSION, 0);
+	SDL_GL_SetAttribute(SDL_GL_RED_SIZE,   8);
+	SDL_GL_SetAttribute(SDL_GL_GREEN_SIZE, 8);
+	SDL_GL_SetAttribute(SDL_GL_BLUE_SIZE,  8);
+	SDL_GL_SetAttribute(SDL_GL_ALPHA_SIZE, 8);
+	SDL_GL_SetAttribute(SDL_GL_DEPTH_SIZE, 24);
+	SDL_GL_SetAttribute(SDL_GL_DOUBLEBUFFER, 1);
+	Width  = 960;
+	Height = 544;
+#endif
+
 	Uint32 SDL_Flags = SDL_WINDOW_OPENGL;
